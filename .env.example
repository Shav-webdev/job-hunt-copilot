# Copy to apps/api/.env
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
JWT_SECRET=change-me-run-openssl-rand-base64-32

# Copy to apps/web/.env.local
AUTH_SECRET=change-me-run-openssl-rand-base64-32
API_URL=http://api.jobhunt.svc.cluster.local:3000
NEXTAUTH_URL=http://jobhunt.local:8080

# Shared
GEMINI_API_KEY=your-gemini-key
